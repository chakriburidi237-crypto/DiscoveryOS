# Database Configuration
# Option 1: SQLite (default - works immediately, no setup needed)
DATABASE_URL=sqlite:///./discoveryos.db

# Option 2: PostgreSQL (requires PostgreSQL running locally or via Docker)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/discoveryos

# Application Settings
DEBUG=False
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS Settings (IMPORTANT: Update for production)
# For Development (localhost only):
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:5173"]

# For Production (update with your actual domain):
# CORS_ORIGINS=["https://yourdomain.com", "https://app.yourdomain.com", "https://dashboard.yourdomain.com"]

# Upload Limits
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes
MAX_TEXT_LENGTH=5242880   # 5 MB in bytes

# LLM Configuration for Theme Labeling
# LLM_PROVIDER can be: "openai" or "anthropic" (default: openai)
LLM_PROVIDER=openai

# For OpenAI API (GPT-4 or GPT-3.5-turbo)
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-3.5-turbo

# For Anthropic Claude API (alternative to OpenAI)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# LLM_MODEL=claude-3-sonnet-20240229

